<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.kreeda.preranascout"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="34" />

    <permission
        android:name="com.kreeda.preranascout.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.kreeda.preranascout.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:name="com.kreeda.preranascout.KreedaApp"
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KreedaPrerana" >
        <activity
            android:name="com.kreeda.preranascout.ui.main.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.KreedaPrerana.Splash" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.kreeda.preranascout.ui.main.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.KreedaPrerana" />
        <activity
            android:name="com.kreeda.preranascout.ui.athlete.AddAthleteActivity"
            android:label="Add Athlete"
            android:parentActivityName="com.kreeda.preranascout.ui.main.MainActivity" />
        <activity
            android:name="com.kreeda.preranascout.ui.athlete.AthleteDetailActivity"
            android:label="Athlete Details"
            android:parentActivityName="com.kreeda.preranascout.ui.main.MainActivity" />
        <activity
            android:name="com.kreeda.preranascout.ui.trial.TrialLoggerActivity"
            android:label="Trial Logger"
            android:parentActivityName="com.kreeda.preranascout.ui.main.MainActivity" />
        <activity
            android:name="com.kreeda.preranascout.ui.trial.BatchEntryActivity"
            android:label="Batch Entry"
            android:parentActivityName="com.kreeda.preranascout.ui.main.MainActivity" />
        <activity
            android:name="com.kreeda.preranascout.ui.leaderboard.LeaderboardActivity"
            android:label="Leaderboard"
            android:parentActivityName="com.kreeda.preranascout.ui.main.MainActivity" />
        <activity
            android:name="com.kreeda.preranascout.ui.talentcurve.TalentCurveActivity"
            android:label="Talent Curve"
            android:parentActivityName="com.kreeda.preranascout.ui.main.MainActivity" />

        <service
            android:name="androidx.room.MultiInstanceInvalidationService"
            android:directBootAware="true"
            android:exported="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.kreeda.preranascout.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <uses-library
            android:name="androidx.window.extensions"
            android:required="false" />
        <uses-library
            android:name="androidx.window.sidecar"
            android:required="false" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>