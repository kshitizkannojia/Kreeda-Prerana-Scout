<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".KreedaApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KreedaPrerana"
        tools:targetApi="34">

        <activity
            android:name=".ui.main.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.KreedaPrerana.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.KreedaPrerana" />

        <activity
            android:name=".ui.athlete.AddAthleteActivity"
            android:label="Add Athlete"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.athlete.AthleteDetailActivity"
            android:label="Athlete Details"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.trial.TrialLoggerActivity"
            android:label="Trial Logger"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.trial.BatchEntryActivity"
            android:label="Batch Entry"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.leaderboard.LeaderboardActivity"
            android:label="Leaderboard"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.talentcurve.TalentCurveActivity"
            android:label="Talent Curve"
            android:parentActivityName=".ui.main.MainActivity" />

    </application>
</manifest>
